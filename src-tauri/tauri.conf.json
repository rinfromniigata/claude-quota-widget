{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Quota Widget",
  "version": "2.1.1",
  "identifier": "com.arnob.claudequotawidget",
  "build": {
    "beforeDevCommand": "bun run dev:vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Claude クォータウィジェット",
        "label": "main",
        "width": 520,
        "height": 680,
        "minWidth": 420,
        "minHeight": 500,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "nsis"],
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
